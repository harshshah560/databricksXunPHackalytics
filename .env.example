# ─── Mapbox (REQUIRED for map tiles) ───────────
# Sign up free at https://www.mapbox.com/ → Account → Access Tokens
VITE_MAPBOX_TOKEN= "pk.eyJ1IjoiYWRpdHlhamhhIiwiYSI6ImNtbHg2azZnODBzODAzZW9rd2hvM282dDAifQ.NwpOGI06I3E_YTbEex9vrQ"

# ─── Databricks SQL API (for live data) ────────
# Get these from your Databricks workspace:
# 1. Host: your workspace URL (e.g. https://adb-xxxx.azuredatabricks.net)
# 2. Token: Settings → Developer → Access Tokens → Generate New Token
# 3. Warehouse ID: SQL Warehouses → click your warehouse → Connection Details → HTTP Path (last segment)
VITE_DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
VITE_DATABRICKS_TOKEN=dapi_your_token_here
VITE_DATABRICKS_WAREHOUSE_ID=your_warehouse_id_here
VITE_DATABRICKS_CATALOG=main
VITE_DATABRICKS_SCHEMA=default

# ─── Optional: RAG Chat Endpoint ───────────────
# If you've deployed a RAG model serving endpoint on Databricks
# VITE_RAG_ENDPOINT=https://adb-xxxx.azuredatabricks.net/serving-endpoints/your-rag-endpoint/invocations

# ─── Optional: Simulation Endpoint ─────────────
# If you've deployed a GPT agent for crisis simulation
# VITE_SIMULATION_ENDPOINT=https://your-simulation-api.com/simulate
